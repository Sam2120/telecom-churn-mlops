# AWS S3 Configuration for DVC
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-telecom-churn-bucket

# MLflow Configuration
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=telecom_churn_prediction
MLFLOW_S3_ENDPOINT_URL=https://s3.amazonaws.com

# Hugging Face
HF_TOKEN=your_huggingface_token
HF_MODEL_REPO=your-username/telecom-churn-model

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Database (Optional - for production)
DATABASE_URL=postgresql://user:password@localhost:5432/telecom_churn

# Model Paths
MODEL_PATH=models/churn_model.pkl
PCA_MODEL_PATH=models/pca_model.pkl
PREPROCESSOR_PATH=models/preprocessor.pkl
